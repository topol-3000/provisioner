# provisioner — local dev environment variables
# ------------------------------------------------------------
# Copy to `.env` (gitignored). The Pydantic Settings class in
# src/provisioning_worker/settings.py loads from this file in dev.

# ----- Environment / app -----
ENVIRONMENT=dev
LOG_LEVEL=INFO

# ----- Database (matches the platform-infra defaults) -----
# Both async app and Alembic use psycopg (psycopg3). The Postgres `platform`
# database has a `provisioning` schema owned by this worker.
DATABASE_URL=postgresql+psycopg://platform:platform_dev_password@localhost:5432/platform
DATABASE_URL_SYNC=postgresql+psycopg://platform:platform_dev_password@localhost:5432/platform

# ----- Valkey (event bus + task queue) -----
VALKEY_URL=redis://localhost:6379/0

# ----- Consumer group -----
PROVISIONING_CONSUMER_GROUP=cg.provisioning-convergence
CONSUMER_NAME=worker-1
CONSUMER_RECLAIM_MIN_IDLE_MS=60000

# ----- Adapters -----
DEPLOYMENT_ADAPTER=fake
NOTIFICATION_TRANSPORT=console

# ----- Health server -----
HEALTH_PORT=8001

# ----- Outbox relay -----
OUTBOX_POLL_SECONDS=1.0
OUTBOX_BATCH_SIZE=100

# ----- Instance provisioning -----
INSTANCE_DOMAIN_SUFFIX=example.local
ODOO_BASE_IMAGE=odoo:17

# ----- OpenTelemetry (optional in dev; export only if endpoint set) -----
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=provisioning-worker

# ----- M2 / secrets (commented out — not used in M1) -----
# COOLIFY_API_URL=
# COOLIFY_API_TOKEN=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
